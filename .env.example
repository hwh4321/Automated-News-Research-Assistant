# ===== LLM 配置 =====
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ===== 搜索 API 配置 =====
# serpapi | newsapi | tavily
SEARCH_ENGINE=serpapi
SEARCH_API_KEY=your-search-api-key

# ===== 邮件 SMTP 配置 =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ===== 存储路径 =====
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_PATH=./data/research.db

# ===== 嵌入模型（中文推荐 shibing624/text2vec-base-chinese）=====
# 本地路径示例: C:/Users/xxx/.cache/huggingface/hub/models--shibing624--text2vec-base-chinese/snapshots/xxx
EMBEDDING_MODEL_PATH=C:/Users/32433/.cache/huggingface/hub/models--shibing624--text2vec-base-chinese/snapshots/183bb99aa7af74355fb58d16edf8c13ae7c5433e

# ===== Redis（可选，不设置则使用内存存储）=====
# REDIS_URL=redis://localhost:6379/0
SESSION_TTL=3600

# ===== 限制 =====
MAX_SEARCH_RESULTS=10
MAX_RETRIES=3
